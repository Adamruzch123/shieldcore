<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Segoe UI', Roboto, Arial, sans-serif; background: #f8f9fa; color: #202124; font-size: 14px; overflow: hidden; height: 100vh; }
.top-bar { display: flex; align-items: center; padding: 12px 22px; border-bottom: 1px solid #ebebeb; background: #fff; }
.google-logo-img { height: 30px; margin-right: 30px; }
.search-bar { flex: 1; max-width: 600px; display: flex; align-items: center; border: 1px solid #dfe1e5; border-radius: 24px; padding: 7px 18px; box-shadow: 0 1px 6px rgba(32,33,36,0.10); }
.search-bar input { flex: 1; border: none; outline: none; font-size: 16px; background: transparent; }
.top-right { margin-left: auto; display: flex; align-items: center; gap: 14px; }
.top-right .grid-icon { font-size: 20px; color: #5f6368; cursor: pointer; }
.top-right .avatar { width: 32px; height: 32px; border-radius: 50%; background: #34a853; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold; }
.tabs-bar { display: flex; align-items: center; padding: 0 20px 0 152px; border-bottom: 1px solid #ebebeb; font-size: 13px; background: #fff; }
.tabs-left { display: flex; gap: 0; }
.tabs-left a { color: #5f6368; text-decoration: none; padding: 12px 16px; border-bottom: 3px solid transparent; }
.tabs-left a.active { color: #1a73e8; border-bottom-color: #1a73e8; font-weight: 500; }
.tabs-right { margin-left: auto; display: flex; gap: 16px; padding-right: 10px; }
.tabs-right a { color: #5f6368; text-decoration: none; padding: 12px 8px; }
.fake-results { max-width: 650px; margin: 0 auto; padding: 24px 20px; filter: blur(3px); opacity: 0.55; }
.fake-result { margin-bottom: 22px; }
.fake-result .url { font-size: 12px; color: #202124; }
.fake-result .title { font-size: 18px; color: #1a0dab; margin: 4px 0; }
.fake-result .desc { font-size: 13px; color: #4d5156; line-height: 1.5; }
.overlay { position: fixed; inset: 0; background: rgba(32,33,36,0.75); display: flex; align-items: center; justify-content: center; z-index: 9999; padding: 20px; animation: fadeIn 0.3s ease-out; backdrop-filter: blur(4px); }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes pop { 0% { transform: scale(0.88) translateY(15px); opacity: 0; } 100% { transform: scale(1) translateY(0); opacity: 1; } }
@keyframes pulse { 0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(26,115,232,0.55); } 50% { transform: scale(1.06); box-shadow: 0 0 0 18px rgba(26,115,232,0); } }
.modal { background: #fff; border-radius: 14px; box-shadow: 0 24px 70px rgba(0,0,0,0.45); max-width: 580px; width: 100%; overflow: hidden; animation: pop 0.4s cubic-bezier(.2,.9,.3,1.2); }
.modal-header { background: #fff; color: #202124; padding: 18px 24px; display: flex; align-items: center; gap: 12px; font-size: 15px; font-weight: 600; border-bottom: 1px solid #ebebeb; }
.modal-header .lock-ico { width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; }
.modal-header .url-fake { margin-left: auto; font-size: 12px; color: #5f6368; font-family: 'Roboto Mono', monospace; background: #f1f3f4; padding: 4px 10px; border-radius: 12px; }
.modal-body { padding: 28px 32px 24px 32px; }
.title-row { display: flex; align-items: center; gap: 20px; margin-bottom: 22px; }
.g-icon-wrap { position: relative; flex-shrink: 0; width: 84px; height: 84px; animation: pulse 1.8s infinite; border-radius: 50%; background: #e8f0fe; display: flex; align-items: center; justify-content: center; }
.g-icon-wrap svg { width: 52px; height: 52px; display: block; }
.g-icon-wrap .alert-badge { position: absolute; bottom: -2px; right: -4px; width: 30px; height: 30px; border-radius: 50%; background: #ea4335; color: #fff; font-size: 18px; font-weight: 900; display: flex; align-items: center; justify-content: center; border: 3px solid #fff; line-height: 1; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
.title-text h1 { font-size: 22px; font-weight: 600; color: #202124; line-height: 1.3; margin-bottom: 5px; letter-spacing: -0.2px; }
.title-text h1 .danger { color: #ea4335; font-weight: 700; }
.title-date { color: #5f6368; font-size: 12px; }
.warning-p1 { color: #c5221f; font-size: 14px; line-height: 1.6; margin-bottom: 14px; background: #fef7e0; padding: 12px 14px; border-left: 4px solid #f9ab00; border-radius: 6px; }
.warning-p1 .bold { font-weight: 700; }
.info-p { color: #3c4043; font-size: 14px; line-height: 1.65; margin-bottom: 12px; }
.info-p .bold { font-weight: 600; color: #202124; }
.step-p { color: #202124; font-size: 14px; margin: 16px 0 18px; font-weight: 500; background: #e8f0fe; padding: 12px 14px; border-radius: 6px; border-left: 3px solid #1a73e8; }
.step-p .bold { font-weight: 700; }
.action-row { display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid #ebebeb; gap: 16px; }
.timer-text { color: #ea4335; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
.timer-text::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #ea4335; animation: blink 1s infinite; box-shadow: 0 0 8px rgba(234,67,53,0.7); }
@keyframes blink { 50% { opacity: 0.2; } }
.threat-list { display: flex; flex-direction: column; gap: 8px; margin: 16px 0 8px; }
.threat-item { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: #fff; border: 1px solid #e8eaed; border-radius: 8px; transition: background 0.2s; }
.threat-item:hover { background: #fafafa; }
.threat-ico { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; flex-shrink: 0; color: #fff; }
.threat-ico.malware { background: #ea4335; }
.threat-ico.spyware { background: #f9ab00; }
.threat-ico.adware { background: #c5221f; }
.threat-info { flex: 1; min-width: 0; }
.threat-name { font-size: 14px; font-weight: 600; color: #202124; line-height: 1.3; }
.threat-desc { font-size: 12px; color: #5f6368; margin-top: 2px; }
.threat-status { font-size: 10px; font-weight: 700; color: #ea4335; background: #fce8e6; padding: 4px 8px; border-radius: 10px; letter-spacing: 0.5px; flex-shrink: 0; }
.secure-text { color: #5f6368; font-size: 12px; font-weight: 500; display: flex; align-items: center; gap: 4px; }
.step2-overlay { position: fixed; inset: 0; background: rgba(32,33,36,0.92); z-index: 100000; display: none; align-items: center; justify-content: center; padding: 20px; animation: fadeIn 0.3s ease-out; backdrop-filter: blur(6px); }
.step2-overlay.active { display: flex; }
.step2-content { text-align: center; color: #fff; max-width: 720px; animation: pop 0.45s cubic-bezier(.2,.9,.3,1.2); }
.step2-content h2 { font-size: 38px; font-weight: 700; line-height: 1.25; margin-bottom: 18px; letter-spacing: -0.4px; }
.step2-content h2 .hl { color: #fbbc04; }
.step2-content p { font-size: 17px; line-height: 1.55; color: #e8eaed; margin-bottom: 14px; }
.step2-content .file-row { display: inline-flex; align-items: center; gap: 14px; background: #fff; color: #202124; padding: 14px 22px; border-radius: 10px; margin-top: 24px; font-size: 15px; font-weight: 600; box-shadow: 0 8px 28px rgba(251,188,4,0.4), 0 0 0 2px rgba(251,188,4,0.5); text-decoration: none; transition: transform 0.2s; }
.step2-content .file-row:hover { transform: translateY(-2px); }
.step2-content .file-row .file-ico { width: 32px; height: 32px; background: #1a73e8; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 11px; }
.arrow-pointer { position: fixed; top: 50px; right: 22%; z-index: 100001; width: 220px; height: 110px; pointer-events: none; animation: arrowSlide 1s ease-in-out infinite alternate; }
@keyframes arrowSlide { 0% { transform: translateX(0); } 100% { transform: translateX(34px); } }
.arrow-pointer svg { width: 100%; height: 100%; filter: drop-shadow(0 0 22px rgba(251,188,4,0.95)); }
.target-ring { position: fixed; top: 8px; right: 70px; width: 60px; height: 60px; border-radius: 50%; border: 3px solid #fbbc04; z-index: 100001; pointer-events: none; animation: targetPulse 1.2s ease-out infinite; }
@keyframes targetPulse { 0% { box-shadow: 0 0 0 0 rgba(251,188,4,0.75); transform: scale(1); } 100% { box-shadow: 0 0 0 34px rgba(251,188,4,0); transform: scale(1.18); } }
.proceed-btn { display: inline-block; background: #1a73e8; color: #fff; font-size: 15px; font-weight: 500; padding: 12px 32px; border: none; border-radius: 6px; cursor: pointer; text-decoration: none; box-shadow: 0 1px 3px rgba(60,64,67,0.3), 0 1px 2px rgba(60,64,67,0.15); transition: all 0.2s; letter-spacing: 0.2px; }
.proceed-btn:hover { background: #1765cc; box-shadow: 0 2px 6px rgba(60,64,67,0.3); }
@media (max-width: 600px) {
  .tabs-bar { padding-left: 20px; }
  .modal-body { padding: 22px 20px; }
  .title-row { flex-direction: column; align-items: flex-start; gap: 12px; }
  .action-row { flex-direction: column; align-items: stretch; }
  .proceed-btn { width: 100%; text-align: center; }
  .title-text h1 { font-size: 20px; }
  .step2-content h2 { font-size: 28px; }
  .step2-content p { font-size: 15px; }
  .arrow-pointer { width: 130px; height: 65px; top: 18px; right: 8%; }
}
</style>
</head>
